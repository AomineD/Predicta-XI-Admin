# ─────────────────────────────────────────────────────────────────────────────
# Admin Panel — Environment
# Server-side only. Never exposed to the browser (no NEXT_PUBLIC_ prefix used).
# ─────────────────────────────────────────────────────────────────────────────

# Backend connection.
#
# Dokploy: when admin panel + backend live in the same Project, they share a
# Docker network. Use the backend service's "App Name" (as configured in
# Dokploy) as the hostname — DNS is internal, traffic never leaves the host,
# ping is sub-millisecond, and the URL is unreachable from the public internet.
#
#   BACKEND_URL=http://predicta-backend:3000
#
# Replace `predicta-backend` with whatever you named the backend service.
# Local dev (running `next dev` directly): http://localhost:3000
BACKEND_URL=http://predicta-backend:3000

# Must match backend's ADMIN_SECRET (forwarded as X-Admin-Token header).
ADMIN_TOKEN=your-admin-secret-here

# Session JWT signing key. Generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-at-least-32-chars
